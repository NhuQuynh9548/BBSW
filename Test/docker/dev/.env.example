# Development Environment Variables
# Copy this file to .env and update values
# Dev frontend uses port 4000 to avoid conflict with production (3000)

# Database (using existing pg_thuchi on port 5437)
# Internal (Docker): host.docker.internal:5437
# External: 124.158.13.158:30350
POSTGRES_USER=thuchi
POSTGRES_PASSWORD=thuchibluebolt
POSTGRES_DB=bluebolt
DATABASE_URL=postgresql://thuchi:thuchibluebolt@host.docker.internal:5437/bluebolt?schema=public

# Backend (dev port: 4001, prod: 5001)
PORT=4001
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Frontend (dev port: 4000, prod: 3000)
FRONTEND_PORT=4000

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Frontend API config
VITE_API_URL=http://localhost:4001/api
VITE_API_TIMEOUT=30000

