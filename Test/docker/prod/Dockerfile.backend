FROM node:20-alpine

WORKDIR /app

# Install PM2 globally and dependencies for Prisma
RUN apk add --no-cache openssl && \
    npm install -g pm2

# Copy backend package files
COPY src/backend/package*.json ./
COPY src/backend/prisma ./prisma/

# Install dependencies
RUN npm install --production=false

# Generate Prisma client
RUN npx prisma generate

# Copy backend source code
COPY src/backend/ ./

# Build TypeScript to JavaScript
RUN npm run build

# Create uploads directory
RUN mkdir -p uploads && chmod 755 uploads

# Expose port
EXPOSE 5001

# Production command using PM2
CMD ["sh", "-c", "npx prisma migrate deploy && PORT=5001 NODE_ENV=production pm2-runtime start dist/server.js --name backend"]
