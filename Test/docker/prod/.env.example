# Production Environment Variables
# Copy this file to .env and update values
# WARNING: Never commit .env file with real passwords to git!

# Database (using existing pg_thuchi on port 5437)
# Internal (Docker): host.docker.internal:5437
# External: 124.158.13.158:30350
POSTGRES_USER=thuchi
POSTGRES_PASSWORD=thuchibluebolt
POSTGRES_DB=bluebolt
DATABASE_URL=postgresql://thuchi:thuchibluebolt@host.docker.internal:5437/bluebolt?schema=public

# Backend
PORT=5001
JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE_MIN_32_CHARS
JWT_EXPIRES_IN=24h

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Frontend
VITE_API_URL=https://bbplatform.bluebolt.vn/api
VITE_API_TIMEOUT=30000
